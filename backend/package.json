{
  "name": "niffyinsure-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc",
    "lint": "eslint src",
    "test": "jest --passWithNoTests --forceExit",
    "test:integration": "jest --testPathPattern=integration --forceExit"
  },
  "dependencies": {
    "bullmq": "^5.12.0",
    "express": "^4.21.2",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/express": "^5",
    "@types/jest": "^29",
    "@types/node": "^22",
    "@types/supertest": "^6",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "jest": "^29",
    "supertest": "^7",
    "ts-jest": "^29",
    "typescript": "^5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "testTimeout": 30000,
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    }
  }
}
